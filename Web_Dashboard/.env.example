# =============================================================================
# Web Dashboard environment template
# Copy to .env (never committed) and fill in the values.
# Loaded server-side only via dotenv; never exposed to client JS.
# =============================================================================

# --- Agora credentials (per .cursorrules §4.3.1) ---------------------------
# v1 topology: ONE shared App ID + Certificate for all tenants. Tenant
# isolation happens via channel naming convention (t-<tenantId>-<pairingCode>),
# not separate Agora projects. The src/agora.js getAgoraCredentials() function
# is the single seam where we'd swap in per-tenant credentials later.
#
# Get both values from https://console.agora.io > Project Management.
# AGORA_APP_ID is technically safe to expose (sent in plaintext to Agora
# servers anyway), but we keep it server-side so all rotation lives in one
# place. AGORA_APP_CERTIFICATE is a hard secret — never expose to clients.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# RTC token TTL in seconds. Per .cursorrules §4.3.1, short-lived (30–60 min);
# the client SDK refetches on the `token-privilege-will-expire` event.
AGORA_TOKEN_TTL_SECONDS=1800

# --- HTTP server -----------------------------------------------------------
PORT=3000

# --- Tenant config ---------------------------------------------------------
# v1: single hardcoded tenant. The id is still threaded through every code
# path so multi-tenant becomes a config change, not a refactor.
DEFAULT_TENANT_ID=default
